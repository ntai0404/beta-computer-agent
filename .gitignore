# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# Environments
.venv/
venv/
env/

# Secrets
.env
.env.local

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Runtime state — never committed
var/runtime/
var/sandbox/

# Cache — never committed
var/cache/

# Downloaded / extracted models — never committed (large binary)
var/models/

# Character assets — large external binaries, never committed
var/assets/characters/**
!var/assets/characters/**/.gitkeep

# Generated audio artifacts
var/artifacts/audio/**
!var/artifacts/audio/.gitkeep

# Voice analysis results
var/artifacts/voice-analysis/**
!var/artifacts/voice-analysis/.gitkeep

# Character inspection/import reports
var/artifacts/character-inspection/
var/artifacts/character-import/

# Reference audio/video — copyrighted external content
# (user-supplied, must not be committed)
profiles/characters/*/references/

# Logs
*.log
